# changes needed to be made to anylog env vars
COMPANY_NAME=Anylog-Demo
REST_BIND=false
BROKER_BIND=false
TCP_BIND=false
LEDGER_CONN=127.0.0.1:32148
ENABLE_MQTT=true
MQTT_BROKER=172.104.228.251
NIC_TYPE=enp2s0
MSG_DBMS=new_company
NODE_MONITORING=true
STORE_MONITORING=true
SYSLOG_MONITORING=true
DOCKER_MONITORING=true
DEFAULT_DBMS=new_company
ENABLE_REMOTE_GUI=true
REMOTE_GUI_TAG=ova-demo
REMOTE_GUI_NIC=
REMOTE_GUI_FE=31800
REMOTE_GUI_BE=8080
# for determining AnyLog version to run not for env vars
COMPOSE_VER=demo-ova
TAG=1.5.2604

